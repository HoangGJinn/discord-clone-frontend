# --- CẤU HÌNH API URL ---

# TRƯỜNG HỢP 1: Chạy trên Máy ảo Android (Android Emulator)
# Android quy định 10.0.2.2 là địa chỉ trỏ về máy tính của bạn
EXPO_PUBLIC_API_URL=http://10.0.2.2:8085/api

# TRƯỜNG HỢP 2: Chạy trên Điện thoại thật (Qua Wifi / Expo Go)
# Bạn phải dùng IP mạng LAN của máy tính (Mở CMD gõ ipconfig để xem)
# Ví dụ: 192.168.1.5
# EXPO_PUBLIC_API_URL=http://192.168.1.5:8085/api

# --- CẤU HÌNH SOCKET (Chat Realtime) ---
# Lưu ý Socket thường dùng giao thức ws:// thay vì http://
EXPO_PUBLIC_SOCKET_URL=ws://10.0.2.2:8085/ws-native
# Hoặc cho máy thật:
# EXPO_PUBLIC_SOCKET_URL=ws://192.168.1.5:8085/ws-native