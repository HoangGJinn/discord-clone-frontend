# ==============================================================
# HƯỚNG DẪN SETUP MÔI TRƯỜNG (FRONTEND):
# 1. Copy file này và đổi tên thành ".env"
# 2. Chọn 1 trong 2 trường hợp bên dưới để bỏ comment (#)
# 3. Tắt server Expo và chạy lại (npx expo start --clear)
# ==============================================================

# --------------------------------------------------------------
# TRƯỜNG HỢP A: Chạy trên Máy ảo Android (Emulator)
# Android Emulator dùng IP 10.0.2.2 để gọi về localhost máy tính
# --------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://10.0.2.2:8085/api
EXPO_PUBLIC_SOCKET_URL=ws://10.0.2.2:8085/ws-native

# --------------------------------------------------------------
# TRƯỜNG HỢP B: Chạy trên Điện thoại thật (Quét mã QR Expo Go)
# 1. Mở CMD trên máy tính, gõ 'ipconfig' để lấy IPv4 (VD: 192.168.1.15)
# 2. Thay IP đó vào bên dưới và bỏ dấu # ở đầu dòng đi
# --------------------------------------------------------------
# EXPO_PUBLIC_API_URL=http://192.168.1.15:8085/api
# EXPO_PUBLIC_SOCKET_URL=ws://192.168.1.15:8085/ws-native
